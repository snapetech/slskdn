<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>slskdn</id>
    <version>2026042900-slskdn.195</version>
    <title>slskdn</title>
    <authors>snapetech</authors>
    <projectUrl>https://github.com/snapetech/slskdn</projectUrl>
    <licenseUrl>https://github.com/snapetech/slskdn/blob/master/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <tags>slskdn soulseek p2p community-service content-sharing</tags>
    <summary>slskdN, an unofficial batteries-included fork of slskd</summary>
    <description>slskdN is an unofficial fork of slskd with batteries-included Soulseek features: SongID, Discovery Graph, multi-source downloads, DHT mesh networking, auto-replace, wishlist, and security hardening.</description>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
