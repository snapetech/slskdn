# Example for VPN_PORT_FORWARD_BACKEND=static.
# Install as /etc/slskdN-vpn/static-forwards/pf0.env.
# public_port and public_ip are required.
public_port=51000
public_ip=203.0.113.10

# Optional guardrails. If present, the agent verifies these match the
# discovered slskdN slot before writing runtime state.
local_port=50300
proto=tcp
